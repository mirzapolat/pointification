# Supabase project (find these in your Supabase dashboard → Project Settings → API)
# VITE_* vars are inlined into the SPA bundle at build time.
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: link shown on the "support / donate" button. Leave blank to hide it.
VITE_DONATE_URL=

# Optional: host port the container is published on (defaults to 3000).
PORT=3000
